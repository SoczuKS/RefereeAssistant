<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        {% block body %}
            <nav id="main_menu">
                {% block navigation %}
                    {{ knp_menu_render('mainMenu', {'template': 'menu/image_based_menu.html.twig'}) }}

                    <div id="page_title">
                        {% block page_title %}
                        {% endblock %}
                    </div>
                {% endblock %}
            </nav>
            <div id="content">
                {% block content %}
                {% endblock %}
            </div>
        {% endblock %}
    </body>
</html>
