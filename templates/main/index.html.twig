{% extends 'base.html.twig' %}

{% block title %}{{ "pages.main" | trans | capitalize }}{% endblock %}

{% block content %}
    <div id="welcome_message">
        {{ 'main_page.introduction' | trans | capitalize }}

        {% if not app.user %}
            {{ 'user.guest' | trans }}
        {% else %}
            {{ app.user.email }}
        {% endif %}
    </div>

    {% if not app.user %}
        <div id="login_register_panel">
            <a href="{{ path('login') }}">
                <span>{{ 'pages.login' | trans | capitalize }}</span>
            </a>

            <a href="{{ path('registration') }}">
                <span>{{ 'pages.register' | trans | capitalize }}</span>
            </a>
        </div>
    {% endif %}

{% endblock %}